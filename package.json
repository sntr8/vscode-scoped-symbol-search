{
    "name": "scoped-symbol-search",
    "displayName": "Scoped Symbol Search",
    "description": "VS Code extension for file and symbol search scoped to the current workspace folder",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": ["Other"],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "scopedSymbolSearch.search",
                "title": "Scoped Symbol Search: Search in Current Folder"
            }
        ],
        "keybindings": [
            {
                "command": "scopedSymbolSearch.search",
                "key": "ctrl+alt+t",
                "mac": "cmd+alt+t"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    }
}
