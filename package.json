{
    "name": "scoped-search",
    "displayName": "Scoped Symbol Search",
    "description": "Search files and symbols scoped to the active workspace folder, useful in multi-root workspaces where global search returns too many results from unrelated folders",
    "version": "0.0.1",
    "publisher": "sntr",
    "repository": {
        "type": "git",
        "url": "https://github.com/sntr8/vscode-scoped-search"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": ["Other"],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "scopedSymbolSearch.search",
                "title": "Scoped Symbol Search: Search in Current Folder"
            }
        ],
        "keybindings": [
            {
                "command": "scopedSymbolSearch.search",
                "key": "ctrl+alt+t",
                "mac": "cmd+alt+t"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    }
}
